# Client Environment Variables
# Copy this file to .env.local (Vite convention) and fill in values.

# ── API ───────────────────────────────────────────────────────────────────────
# Your production backend URL — no trailing slash
VITE_API_URL=https://api.your-app-domain.com

# ── Socket.IO ─────────────────────────────────────────────────────────────────
# Backend socket server URL — usually the same as API URL
VITE_SOCKET_URL=https://api.your-app-domain.com
