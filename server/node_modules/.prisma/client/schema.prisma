datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id        String   @id @default(uuid())
  username  String   @unique
  email     String   @unique
  password  String
  xp        Int      @default(0)
  level     Int      @default(1)
  createdAt DateTime @default(now())

  // Relations
  roomId      String? // Current lobby the user is occupying
  rooms       Room[]   @relation("HostRelation")
  currentRoom Room?    @relation("MemberRelation", fields: [roomId], references: [id], onDelete: SetNull)
  results     Result[]
}

model Paragraph {
  id        String  @id @default(uuid())
  text      String
  source    String?
  category  String  @default("english")
  wordCount Int

  // Relations
  matches Match[]
}

model Room {
  id              String @id @default(uuid())
  code            String @unique
  hostId          String
  status          String @default("LOBBY")
  configDuration  Int    @default(30)
  configMode      String @default("WORDS")
  configWordCount Int    @default(50)

  // Relations
  host    User    @relation("HostRelation", fields: [hostId], references: [id], onDelete: Cascade)
  members User[]  @relation("MemberRelation")
  matches Match[]
}

model Match {
  id          String    @id @default(uuid())
  roomId      String?
  paragraphId String
  startedAt   DateTime  @default(now())
  endedAt     DateTime?

  // Relations
  room      Room?     @relation(fields: [roomId], references: [id], onDelete: Cascade)
  paragraph Paragraph @relation(fields: [paragraphId], references: [id], onDelete: Restrict)
  results   Result[]
}

model Result {
  id               String @id @default(uuid())
  matchId          String
  userId           String
  wpm              Int
  accuracy         Float
  position         Int
  wpmHistory       String
  keystrokeHistory String

  // Relations
  match Match @relation(fields: [matchId], references: [id], onDelete: Cascade)
  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
}
