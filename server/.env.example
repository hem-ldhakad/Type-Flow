# Server Environment Variables
# Copy this file to .env and fill in all required values before running.

# ── Server ────────────────────────────────────────────────────────────────────
PORT=5000
NODE_ENV=production

# ── Database ──────────────────────────────────────────────────────────────────
# PostgreSQL connection string
# For Railway: copy the DATABASE_URL from your Railway PostgreSQL service
# For local:   postgresql://postgres:password@localhost:5432/typeflow
DATABASE_URL="postgresql://postgres:MdQeuledEIwgDVpAjnfRgFUylmeBxbox@sakura.proxy.rlwy.net:16616/railway"

# ── Authentication ─────────────────────────────────────────────────────────────
# REQUIRED: Generate with:
#   node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=REPLACE_WITH_A_LONG_RANDOM_SECRET_AT_LEAST_64_CHARS

# ── CORS ───────────────────────────────────────────────────────────────────────
# Your production frontend URL — no trailing slash
CORS_ORIGIN=https://your-app-domain.com

# ── Rate Limiting ─────────────────────────────────────────────────────────────
# Max requests per 15-minute window per IP (default: 100)
RATE_LIMIT_MAX=100
